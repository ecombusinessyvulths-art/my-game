<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>6Club Pro - Multi-Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #0f0f1b; color: white; font-family: sans-serif; -webkit-tap-highlight-color: transparent; }
        .gradient-bg { background: linear-gradient(135deg, #32324a 0%, #1a1a2e 100%); }
        .gold-theme { background: linear-gradient(to bottom, #ffeb8c, #ffbb3d); color: #5c3b00; }
        .timer-cell { background-color: #2b2b3d; color: white; border-radius: 4px; padding: 4px 6px; margin: 0 1px; min-width: 24px; text-align: center; font-weight: bold; }
        .ball { width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; box-shadow: inset -3px -3px 6px rgba(0,0,0,0.3); }
        .ball-red { background: radial-gradient(circle at 30% 30%, #ff5f5f, #cc0000); }
        .ball-green { background: radial-gradient(circle at 30% 30%, #4ade80, #166534); }
        .ball-violet { background: radial-gradient(circle at 30% 30%, #a855f7, #6b21a8); }
        .ball-0 { background: linear-gradient(135deg, #a855f7 50%, #cc0000 50%); }
        .ball-5 { background: linear-gradient(135deg, #a855f7 50%, #166534 50%); }
        .bet-lock { pointer-events: none; filter: grayscale(0.8); opacity: 0.5; }
        .tab-active { background: linear-gradient(to bottom, #ffeb8c, #ffbb3d) !important; color: #5c3b00 !important; opacity: 1 !important; }
    </style>
</head>
<body class="max-w-md mx-auto min-h-screen pb-10">

    <nav class="flex justify-between items-center p-4">
        <i class="fa-solid fa-chevron-left"></i>
        <div class="flex items-center gap-1"><span class="text-2xl font-black italic">6</span><span class="font-bold uppercase">Club</span></div>
        <i class="fa-solid fa-headset text-xl"></i>
    </nav>

    <div class="px-4 mb-4">
        <div class="gradient-bg rounded-3xl p-6 text-center shadow-lg">
            <span class="text-3xl font-bold block mb-1">₹0.01</span>
            <span class="text-xs text-gray-400"><i class="fa-solid fa-wallet text-yellow-500"></i> Wallet balance</span>
            <div class="flex gap-4 mt-6">
                <button class="flex-1 bg-red-500 py-2 rounded-full font-bold">Withdraw</button>
                <button class="flex-1 bg-green-500 py-2 rounded-full font-bold">Deposit</button>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-4 gap-2 px-4 mb-4" id="game-tabs">
        <button onclick="switchGame('30s', 30)" class="tab-active bg-white/5 rounded-xl p-2 text-center transition">
            <i class="fa-solid fa-clock-rotate-left mb-1"></i><div class="text-[9px] font-bold">WinGo 30s</div>
        </button>
        <button onclick="switchGame('1m', 60)" class="bg-white/5 rounded-xl p-2 text-center opacity-50 transition">
            <i class="fa-solid fa-clock mb-1"></i><div class="text-[9px] font-bold">WinGo 1m</div>
        </button>
        <button onclick="switchGame('3m', 180)" class="bg-white/5 rounded-xl p-2 text-center opacity-50 transition">
            <i class="fa-solid fa-clock mb-1"></i><div class="text-[9px] font-bold">WinGo 3m</div>
        </button>
        <button onclick="switchGame('5m', 300)" class="bg-white/5 rounded-xl p-2 text-center opacity-50 transition">
            <i class="fa-solid fa-clock mb-1"></i><div class="text-[9px] font-bold">WinGo 5m</div>
        </button>
    </div>

    <div class="px-4">
        <div class="gold-theme rounded-xl p-4 flex justify-between items-center mb-6">
            <div>
                <div class="text-xs font-bold mb-1" id="game-title">WinGo 30sec</div>
                <div class="flex gap-1" id="recent-results-mini"></div>
            </div>
            <div class="text-right">
                <div class="flex justify-end text-xl font-mono mb-1" id="timer-ui">
                    <span class="timer-cell">0</span><span class="timer-cell">0</span><span class="text-black mx-1">:</span><span class="timer-cell">0</span><span class="timer-cell">0</span>
                </div>
                <div class="text-[10px] font-bold" id="period-id">Loading...</div>
            </div>
        </div>
    </div>

    <div id="betting-area" class="px-4">
        <div class="grid grid-cols-3 gap-3 mb-6">
            <button class="bg-green-500 py-3 rounded-tr-xl rounded-bl-xl font-bold">Green</button>
            <button class="bg-purple-500 py-3 rounded-lg font-bold">Violet</button>
            <button class="bg-red-500 py-3 rounded-tl-xl rounded-br-xl font-bold">Red</button>
        </div>
        <div class="bg-white/5 rounded-3xl p-5 grid grid-cols-5 gap-4 justify-items-center mb-6">
            <div class="ball ball-0">0</div><div class="ball ball-green">1</div><div class="ball ball-red">2</div><div class="ball ball-green">3</div><div class="ball ball-red">4</div>
            <div class="ball ball-5">5</div><div class="ball ball-red">6</div><div class="ball ball-green">7</div><div class="ball ball-red">8</div><div class="ball ball-green">9</div>
        </div>
    </div>

    <div class="px-4 mt-4">
        <h3 class="text-sm font-bold mb-2 text-yellow-500 underline">Recent History</h3>
        <div class="bg-white/5 rounded-xl overflow-hidden text-[11px]">
            <table class="w-full text-left">
                <thead class="bg-white/10">
                    <tr><th class="p-2">Period</th><th class="p-2">Number</th><th class="p-2">Size</th><th class="p-2">Color</th></tr>
                </thead>
                <tbody id="history-table-body"></tbody>
            </table>
        </div>
    </div>

    <script>
        let currentGame = '30s';
        let duration = 30;
        let timeLeft = 30;
        
        const timers = { '30s': 30, '1m': 60, '3m': 180, '5m': 300 };

        function switchGame(id, time) {
            currentGame = id;
            duration = time;
            timeLeft = time; // Reset time for demo
            document.getElementById('game-title').innerText = `WinGo ${id}`;
            
            // Update Tab UI
            document.querySelectorAll('#game-tabs button').forEach(btn => btn.classList.remove('tab-active'));
            event.currentTarget.classList.add('tab-active');
            updateHistoryUI();
        }

        function generateResult() {
            const num = Math.floor(Math.random() * 10);
            let color = (num % 2 === 0) ? 'Red' : 'Green';
            if (num === 0 || num === 5) color = 'Violet';
            const size = (num <= 4) ? 'Small' : 'Big';
            
            const period = document.getElementById('period-id').innerText;
            const entry = { period, num, color, size };

            let history = JSON.parse(localStorage.getItem(`history_${currentGame}`)) || [];
            history.unshift(entry);
            localStorage.setItem(`history_${currentGame}`, JSON.stringify(history.slice(0, 10)));
            
            updateHistoryUI();
        }

        function updateHistoryUI() {
            const history = JSON.parse(localStorage.getItem(`history_${currentGame}`)) || [];
            const body = document.getElementById('history-table-body');
            body.innerHTML = history.map(h => `
                <tr class="border-b border-white/5">
                    <td class="p-2">${h.period.slice(-4)}</td>
                    <td class="p-2 font-bold text-yellow-400">${h.num}</td>
                    <td class="p-2">${h.size}</td>
                    <td class="p-2">${h.color}</td>
                </tr>
            `).join('');
        }

        setInterval(() => {
            timeLeft--;
            if (timeLeft < 0) {
                generateResult();
                timeLeft = duration;
            }

            // Update UI
            const m = Math.floor(timeLeft / 60).toString().padStart(2, '0');
            const s = (timeLeft % 60).toString().padStart(2, '0');
            const fullStr = m + s;
            document.querySelectorAll('#timer-ui .timer-cell').forEach((c, i) => c.innerText = fullStr[i]);
            
            document.getElementById('period-id').innerText = "20260426" + Math.floor(Date.now()/1000);
            
            // Lock betting in last 5 seconds
            document.getElementById('betting-area').classList.toggle('bet-lock', timeLeft <= 5);
        }, 1000);

        updateHistoryUI();
    </script>
</body>
</html>
